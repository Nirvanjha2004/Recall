# Server Configuration
PORT=3000
NODE_ENV=development
ADMIN_PASSWORD=change_this_to_a_secure_password

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=recall

# Alternative Database URL (takes precedence if provided)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Groq API Configuration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Slack Configuration
# Get these from your Slack App Settings: https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=http://localhost:3000/slack/oauth/callback
